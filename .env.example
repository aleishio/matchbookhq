# Public browser-safe values
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=YC OS
NEXT_PUBLIC_DATA_CLASSIFICATION=public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_POSTHOG_ENABLED=true
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=/matchbook-relay
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
NEXT_PUBLIC_POSTHOG_RECORDINGS_ENABLED=true

# Server-only values for local dev or Vercel Environment Variables
EVENT_PREP_DATA_SOURCE=local
EVENT_APPROVALS_DATA_SOURCE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
DATABASE_URL=

# Voyage embeddings
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-code-3

# Resend email. Use a verified sending subdomain, not the root domain.
RESEND_API_KEY=
RESEND_SENDING_DOMAIN=events.matchbookhq.com
RESEND_FROM_EMAIL=yc@events.matchbookhq.com
RESEND_FROM_NAME=YC OS
RESEND_REPLY_TO_EMAIL=yc@matchbookhq.com
RESEND_WEBHOOK_SECRET=
RESEND_CLARIFICATION_EMAIL_BATCH_SIZE=20
CLARIFICATION_EMAIL_WORKER_STRATEGY=supabase
CLARIFICATION_EMAIL_WORKER_URL=
WEBHOOK_BASE_URL=https://matchbookhq.com

# Lu.ma server-side integration
LUMA_API_KEY=
LUMA_API_BASE_URL=https://public-api.luma.com
# Optional. Sync infers Lu.ma calendar ids per event from the API payload.
LUMA_CALENDAR_ID=
LUMA_WEBHOOK_SECRET=
LUMA_SYNC_SECRET=
LUMA_SYNC_EVENT_PAGE_LIMIT=50
LUMA_SYNC_GUEST_PAGE_LIMIT=100
LUMA_SYNC_REQUEST_SPACING_MS=250
LUMA_WRITEBACK_BATCH_SIZE=20
LUMA_IMMEDIATE_WRITEBACK_BATCH_SIZE=20
LUMA_WRITEBACK_WORKER_STRATEGY=supabase
LUMA_WRITEBACK_WORKER_URL=
AGENT_GUEST_REQUEST_BATCH_SIZE=10
AGENT_GUEST_REQUEST_WORKER_STRATEGY=supabase
AGENT_GUEST_REQUEST_WORKER_URL=

# Optional LLM providers
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_EMAIL_DRAFT_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# gbrain local/dev setup only
GBRAIN_DATABASE_URL=
GBRAIN_SUPABASE_POOLER_URL=
GBRAIN_EMBEDDING_PROVIDER=voyage
GBRAIN_EMBEDDING_MODEL=voyage-code-3

# App secrets
AUTH_SECRET=
SESSION_SECRET=
WEBHOOK_SECRET=
CRON_SECRET=

# Site unlock and agent pairing use the same token. Required outside local dev/test.
YC_OS_ACCESS_TOKEN=
YC_OS_UNLOCK_COOKIE_NAME=yc_os_access_token

# Vercel CLI or GitHub Actions only
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_PROJECT_PRODUCTION_URL=
